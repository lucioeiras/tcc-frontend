# URL base da API do backend (inclua o sufixo /api)
#
# - Backend local sem Docker:        http://localhost:3000/api
# - Backend via Docker Compose:      http://localhost:3002/api
# - Dispositivo físico (Expo Go):    use o IP da sua máquina na rede local,
#   ex.: http://192.168.0.10:3002/api (localhost não funciona no celular)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3002/api
