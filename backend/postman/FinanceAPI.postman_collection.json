        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", ":id"]
            }
          }
        }
      ]
    },
